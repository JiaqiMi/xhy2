<launch>
    <!--
      任务3子任务3：识别指定颜色方框并执行投放。

      manual：人工移动机器人，本节点只负责识别、灯光和夹爪。
      auto：本节点只向motion_supervisor发布绝对目标或取消请求，不直接发布
      /cmd/pose/ned，也不自行计算TX/TY、阻尼或刹车。motion_supervisor由基础
      控制系统统一启动，本任务launch不重复启动；运行auto前只检查接口已就绪。
    -->

    <!-- 运行方式和主循环频率。只测试识别与执行器时改为manual。 -->
    <arg name="operation_mode" default="auto" />
    <arg name="rate" default="5.0" />

    <!-- 普通状态日志和异常日志的节流周期；模型帧进度仍逐帧打印。 -->
    <arg name="log_interval" default="1.0" />
    <arg name="warning_log_interval" default="2.0" />

    <!-- 默认包含彩色方框模型；模型已在其他终端启动时设为false。 -->
    <arg name="start_rectangle_model" default="true" />

    <!--
      模型识别参数。target_color可设为yellow、green或red。
      min_confidence调大可减少误检，调小可增加弱目标召回。
    -->
    <arg name="model_detection_topic" default="/vision/rectangle/detections" />
    <arg name="target_color" default="red" />
    <arg name="min_confidence" default="0.20" />
    <!-- 人工模式下，同一位置候选组达到该帧数后确认。 -->
    <arg name="stable_detection_count" default="5" />
    <!--
      搜索和刹停后的悬停复核都使用最近10个模型帧的滑动窗口。
      无效帧不会清空窗口内的旧有效帧；任意位置候选组累计3帧后立即通过。
      搜索中第一次通过只触发刹停；收到新的HOVER后清空旧窗口重新识别，
      第二次3/10帧通过才进入现有细对准。
    -->
    <arg name="stable_detection_window_size" default="10" />
    <arg name="auto_search_stable_detection_count" default="3" />
    <!--
      首次识别触发刹停后，先等待画面稳定再开始第二轮识别。
      第二轮超时会恢复被打断的原搜索目标，不会结束任务或跳到下一搜索步骤。
    -->
    <arg name="auto_hover_confirm_settle_seconds" default="0.5" />
    <arg name="auto_hover_confirm_timeout" default="4.0" />
    <!-- 下面这个参数只控制现有细对准的最终居中确认，不参与搜索候选组判别。 -->
    <arg name="auto_center_stable_detection_count" default="3" />
    <!--
      新有效帧相对候选组中心中位数的最大二维距离，以及相对面积中位数的变化上限。
      位置容差调大更容易快速成组但可能混入误检；面积容差调大可适应运动时框大小变化。
    -->
    <arg name="stable_center_tolerance_px" default="40.0" />
    <arg name="stable_area_tolerance_ratio" default="0.35" />
    <!-- 目标或模型消息最大允许间隔，以及任务搜索/对齐总超时。 -->
    <arg name="detection_timeout" default="2.0" />
    <arg name="max_wait_seconds" default="300.0" />

    <!-- motion_supervisor任务接口；任务节点不直接设置底层模式和推力。 -->
    <arg name="motion_goal_topic" default="/cmd/motion/goal" />
    <arg name="motion_cancel_topic" default="/cmd/motion/cancel" />
    <arg name="motion_state_topic" default="/motion/state" />
    <arg name="motion_state_timeout" default="0.5" />
    <arg name="motion_startup_timeout" default="10.0" />
    <arg name="cancel_timeout" default="50.0" />

    <!--
      HOVER必须匹配任务最近发布的绝对目标，避免把旧阶段HOVER误判为到达。
      以下三项只用于任务侧核对，不改变motion_supervisor内部控制参数。
    -->
    <arg name="goal_match_position_tolerance" default="0.03" />
    <arg name="goal_match_depth_tolerance" default="0.03" />
    <arg name="goal_match_yaw_tolerance_deg" default="2.0" />

    <!--
      除HOVER和目标匹配外，再检查base_link实际误差、水平速度和航向角速度。
      搜索步骤只有全部通过才切换；动作前还会使用更严格的动作门槛。
    -->
    <arg name="arrival_position_tolerance" default="0.05" />
    <arg name="arrival_yaw_tolerance_deg" default="5.0" />
    <arg name="arrival_max_horizontal_speed" default="0.02" />
    <arg name="arrival_max_yaw_rate_deg_s" default="0.5" />

    <!--
      /status/auv仅用于深度、垂直速度、航向和底层mode=4的动作安全核对，
      不再用于本节点计算推力或阻尼。线速度缩放按实际消息单位调整。
    -->
    <arg name="status_topic" default="/status/auv" />
    <arg name="status_timeout" default="0.5" />
    <arg name="status_linear_velocity_scale" default="1.0" />

    <!--
      自动搜索顺序：固定启动点悬停；第一段前进后左右搜索；
      第二段前进后左右搜索；第三段前进后左右搜索。
      悬停时间、三段前进距离以及左右横移距离均可在下面独立调整。
      每一段都发送一个map绝对目标，并等待匹配目标的HOVER后进入下一段。
    -->
    <arg name="auto_initial_hover_seconds" default="5.0" />
    <arg name="auto_search_first_forward_distance" default="2.0" />
    <arg name="auto_search_second_forward_distance" default="0.30" />
    <arg name="auto_search_third_forward_distance" default="0.20" />
    <!--
      仅控制第一段搜索。false保持“直线前进、左移、右移”；true改为三段之字形：
      前进并左移、前进并跨到右侧、前进并自动回到中线。三段前进距离之和等于
      auto_search_first_forward_distance，航向始终保持任务启动时锁定的当前航向。
    -->
    <arg name="auto_first_segment_zigzag_enabled" default="false" />
    <!--
      左移距离从当前搜索点开始计算；右移距离从左移结束位置开始计算。
      例如左移0.20m后，右移0.20m表示回到原横向位置；
      若希望从左侧-0.20m扫到右侧+0.20m，可将右移距离设为0.40m。
    -->
    <arg name="auto_search_left_distance" default="0.40" />
    <arg name="auto_search_right_distance" default="0.80" />

    <!--
      视觉细对准把归一化像素误差换算成前后、左右位置小步，单位均为m。
      gain越大单帧修正越快；max_step限制单次目标跳变；min_interval限制
      目标更新频率。运动速度、推力、阻尼和刹车在motion_supervisor中调整。
      如果日志持续显示视觉小步已发布但画面中心几乎不变，可小幅增加min_step；
      如果越过图像中心或来回摆动，先减小gain和max_step，再增大min_interval。
    -->
    <arg name="auto_visual_forward_gain_m" default="0.10" />
    <arg name="auto_visual_lateral_gain_m" default="0.10" />
    <arg name="auto_visual_min_step_m" default="0.1" />
    <arg name="auto_visual_max_step_m" default="0.2" />
    <arg name="auto_visual_goal_min_interval" default="0.50" />
    <!-- 现场前后或左右方向相反时，将对应符号改为-1.0。 -->
    <arg name="auto_forward_sign" default="1.0" />
    <arg name="auto_lateral_sign" default="1.0" />

    <!-- 方框期望中心与像素容差；比例0.5/0.5表示图像正中心。 -->
    <arg name="auto_target_center_u_ratio" default="0.5" />
    <arg name="auto_target_center_v_ratio" default="0.5" />
    <arg name="auto_center_tolerance_u_px" default="35.0" />
    <arg name="auto_center_tolerance_v_px" default="35.0" />
    <!-- 模型JSON缺少图像尺寸时使用的回退值。 -->
    <arg name="auto_image_width" default="640.0" />
    <arg name="auto_image_height" default="480.0" />

    <!--
      自动模式动作放行门槛。必须同时满足motion_supervisor到达判定、
      /status/auv的mode=4、垂直速度、深度误差和航向误差。
    -->
    <arg name="auto_action_max_horizontal_speed" default="0.03" />
    <arg name="auto_action_max_vertical_speed" default="0.03" />
    <arg name="auto_action_max_yaw_rate" default="0.05" />
    <arg name="auto_action_max_depth_error" default="0.08" />
    <arg name="auto_action_max_yaw_error_deg" default="5.0" />

    <!-- 人工模式稳定识别后的动作前等待；自动模式不使用该等待。 -->
    <arg name="hold_seconds" default="1.0" />
    <!-- 开灯并打开夹爪后保持最终定点3秒，再关闭夹爪和灯。 -->
    <arg name="open_seconds" default="3.0" />
    <arg name="close_seconds" default="0.0" />

    <!-- 执行器协议参数。子任务3需要三色灯和夹爪，因此mode固定建议为2。 -->
    <arg name="actuator_topic" default="/cmd/actuator" />
    <arg name="actuator_mode" default="2" />
    <arg name="clamp_open" default="0" />
    <arg name="clamp_closed" default="255" />
    <arg name="heading_servo" default="128" />
    <arg name="drive_cmd" default="0" />
    <arg name="drive_speed" default="0" />
    <arg name="light1" default="0" />
    <arg name="light2" default="0" />

    <!-- 启动彩色方框模型、双目深度和网页显示链路。 -->
    <include if="$(arg start_rectangle_model)"
             file="$(find stereo_depth)/launch/test_rectangles_detection.launch" />

    <node pkg="auv_control"
          type="test_task3_3_inspect_and_drop.py"
          name="test_task3_3_inspect_and_drop"
          output="screen">
        <param name="operation_mode" type="string" value="$(arg operation_mode)" />
        <param name="rate" type="double" value="$(arg rate)" />
        <param name="log_interval" type="double" value="$(arg log_interval)" />
        <param name="warning_log_interval" type="double" value="$(arg warning_log_interval)" />

        <param name="model_detection_topic" type="string" value="$(arg model_detection_topic)" />
        <param name="target_color" type="string" value="$(arg target_color)" />
        <param name="min_confidence" type="double" value="$(arg min_confidence)" />
        <param name="stable_detection_count" type="int" value="$(arg stable_detection_count)" />
        <param name="stable_detection_window_size" type="int" value="$(arg stable_detection_window_size)" />
        <param name="auto_search_stable_detection_count" type="int" value="$(arg auto_search_stable_detection_count)" />
        <param name="auto_hover_confirm_settle_seconds" type="double" value="$(arg auto_hover_confirm_settle_seconds)" />
        <param name="auto_hover_confirm_timeout" type="double" value="$(arg auto_hover_confirm_timeout)" />
        <param name="auto_center_stable_detection_count" type="int" value="$(arg auto_center_stable_detection_count)" />
        <param name="stable_center_tolerance_px" type="double" value="$(arg stable_center_tolerance_px)" />
        <param name="stable_area_tolerance_ratio" type="double" value="$(arg stable_area_tolerance_ratio)" />
        <param name="detection_timeout" type="double" value="$(arg detection_timeout)" />
        <param name="max_wait_seconds" type="double" value="$(arg max_wait_seconds)" />

        <param name="motion_goal_topic" type="string" value="$(arg motion_goal_topic)" />
        <param name="motion_cancel_topic" type="string" value="$(arg motion_cancel_topic)" />
        <param name="motion_state_topic" type="string" value="$(arg motion_state_topic)" />
        <param name="motion_state_timeout" type="double" value="$(arg motion_state_timeout)" />
        <param name="motion_startup_timeout" type="double" value="$(arg motion_startup_timeout)" />
        <param name="cancel_timeout" type="double" value="$(arg cancel_timeout)" />
        <param name="goal_match_position_tolerance" type="double" value="$(arg goal_match_position_tolerance)" />
        <param name="goal_match_depth_tolerance" type="double" value="$(arg goal_match_depth_tolerance)" />
        <param name="goal_match_yaw_tolerance_deg" type="double" value="$(arg goal_match_yaw_tolerance_deg)" />
        <param name="arrival_position_tolerance" type="double" value="$(arg arrival_position_tolerance)" />
        <param name="arrival_yaw_tolerance_deg" type="double" value="$(arg arrival_yaw_tolerance_deg)" />
        <param name="arrival_max_horizontal_speed" type="double" value="$(arg arrival_max_horizontal_speed)" />
        <param name="arrival_max_yaw_rate_deg_s" type="double" value="$(arg arrival_max_yaw_rate_deg_s)" />

        <param name="status_topic" type="string" value="$(arg status_topic)" />
        <param name="status_timeout" type="double" value="$(arg status_timeout)" />
        <param name="status_linear_velocity_scale" type="double" value="$(arg status_linear_velocity_scale)" />

        <param name="auto_initial_hover_seconds" type="double" value="$(arg auto_initial_hover_seconds)" />
        <param name="auto_search_first_forward_distance" type="double" value="$(arg auto_search_first_forward_distance)" />
        <param name="auto_search_second_forward_distance" type="double" value="$(arg auto_search_second_forward_distance)" />
        <param name="auto_search_third_forward_distance" type="double" value="$(arg auto_search_third_forward_distance)" />
        <param name="auto_first_segment_zigzag_enabled" type="bool" value="$(arg auto_first_segment_zigzag_enabled)" />
        <param name="auto_search_left_distance" type="double" value="$(arg auto_search_left_distance)" />
        <param name="auto_search_right_distance" type="double" value="$(arg auto_search_right_distance)" />

        <param name="auto_visual_forward_gain_m" type="double" value="$(arg auto_visual_forward_gain_m)" />
        <param name="auto_visual_lateral_gain_m" type="double" value="$(arg auto_visual_lateral_gain_m)" />
        <param name="auto_visual_min_step_m" type="double" value="$(arg auto_visual_min_step_m)" />
        <param name="auto_visual_max_step_m" type="double" value="$(arg auto_visual_max_step_m)" />
        <param name="auto_visual_goal_min_interval" type="double" value="$(arg auto_visual_goal_min_interval)" />
        <param name="auto_forward_sign" type="double" value="$(arg auto_forward_sign)" />
        <param name="auto_lateral_sign" type="double" value="$(arg auto_lateral_sign)" />

        <param name="auto_target_center_u_ratio" type="double" value="$(arg auto_target_center_u_ratio)" />
        <param name="auto_target_center_v_ratio" type="double" value="$(arg auto_target_center_v_ratio)" />
        <param name="auto_center_tolerance_u_px" type="double" value="$(arg auto_center_tolerance_u_px)" />
        <param name="auto_center_tolerance_v_px" type="double" value="$(arg auto_center_tolerance_v_px)" />
        <param name="auto_image_width" type="double" value="$(arg auto_image_width)" />
        <param name="auto_image_height" type="double" value="$(arg auto_image_height)" />

        <param name="auto_action_max_horizontal_speed" type="double" value="$(arg auto_action_max_horizontal_speed)" />
        <param name="auto_action_max_vertical_speed" type="double" value="$(arg auto_action_max_vertical_speed)" />
        <param name="auto_action_max_yaw_rate" type="double" value="$(arg auto_action_max_yaw_rate)" />
        <param name="auto_action_max_depth_error" type="double" value="$(arg auto_action_max_depth_error)" />
        <param name="auto_action_max_yaw_error_deg" type="double" value="$(arg auto_action_max_yaw_error_deg)" />

        <param name="hold_seconds" type="double" value="$(arg hold_seconds)" />
        <param name="open_seconds" type="double" value="$(arg open_seconds)" />
        <param name="close_seconds" type="double" value="$(arg close_seconds)" />
        <param name="actuator_topic" type="string" value="$(arg actuator_topic)" />
        <param name="actuator_mode" type="int" value="$(arg actuator_mode)" />
        <param name="clamp_open" type="int" value="$(arg clamp_open)" />
        <param name="clamp_closed" type="int" value="$(arg clamp_closed)" />
        <param name="heading_servo" type="int" value="$(arg heading_servo)" />
        <param name="drive_cmd" type="int" value="$(arg drive_cmd)" />
        <param name="drive_speed" type="int" value="$(arg drive_speed)" />
        <param name="light1" type="int" value="$(arg light1)" />
        <param name="light2" type="int" value="$(arg light2)" />
    </node>
</launch>
