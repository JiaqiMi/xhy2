<launch>
    <!--
      Yaw 单轴自动测试：±30°、±60°、±90°，每个幅值重复三次。
      每一步均返回初始航向，并等待 HOVER 稳定接管后再继续。
    -->
    <arg name="target_z" default="-0.9" />
    <arg name="repetitions" default="2" />
    <arg name="action_timeout" default="120.0" />
    <arg name="hover_hold_seconds" default="2.0" />
    <arg name="acceptance_yaw_tolerance_deg" default="5.0" />
    <arg name="stable_yaw_rate_threshold_deg_s" default="1.0" />

    <include file="$(find auv_control)/launch/motion_axis_auto_test.launch">
        <arg name="axis" value="yaw" />
        <arg name="target_z" value="$(arg target_z)" />
        <arg name="repetitions" value="$(arg repetitions)" />
        <arg name="action_timeout" value="$(arg action_timeout)" />
        <arg name="hover_hold_seconds" value="$(arg hover_hold_seconds)" />
        <arg name="acceptance_yaw_tolerance_deg"
             value="$(arg acceptance_yaw_tolerance_deg)" />
        <arg name="stable_yaw_rate_threshold_deg_s"
             value="$(arg stable_yaw_rate_threshold_deg_s)" />
    </include>
</launch>
