<launch>
    <!-- Task 3 subtask 1: move to the task acquisition area.
         Start the required vehicle drivers, TF, and controller separately. -->

    <arg name="rate" default="5.0" />

    <!-- mock: use configured offset.
         topic: search for class_name=arrow on /obj/target_message, then move to the detected arrow/frame position. -->
    <arg name="input_mode" default="mock" />
    <arg name="arrow_topic" default="/obj/target_message" />
    <arg name="arrow_class" default="arrow" />
    <arg name="min_confidence" default="0.2" />

    <!-- Offset used only by mock mode. -->
    <arg name="arrow_forward" default="0.50" />
    <arg name="arrow_right" default="0.30" />
    <arg name="arrow_down" default="0.00" />

    <!-- Search points are generated around the start pose.  base_link uses x=front, y=right. -->
    <arg name="search_step" default="0.30" />
    <arg name="max_search_points" default="9" />
    <arg name="scan_yaw_offsets_deg" default="0 30 -30 60 -60 90 -90" />
    <arg name="scan_hold_seconds" default="1.5" />
    <arg name="max_search_seconds" default="60.0" />
    <arg name="search_arrive_dist" default="0.15" />
    <arg name="search_arrive_yaw_deg" default="8.0" />

    <!-- Arrow lock: require several stable detections before moving to the arrow. -->
    <arg name="stable_detection_count" default="5" />
    <arg name="stable_position_tolerance" default="0.15" />
    <arg name="detection_timeout" default="2.0" />

    <!-- current: keep current yaw after reaching arrow.
         detection: use pose.orientation when detector provides real arrow heading.
         fixed: use fixed_arrow_yaw_deg in map. -->
    <arg name="arrow_yaw_mode" default="current" />
    <arg name="fixed_arrow_yaw_deg" default="0.0" />

    <arg name="arrive_dist" default="0.25" />
    <arg name="arrive_yaw_deg" default="8.0" />
    <arg name="hold_seconds" default="2.0" />

    <node pkg="auv_control"
          type="test_task3_1_acquire_area.py"
          name="test_task3_1_acquire_area"
          output="screen">
        <param name="rate" type="double" value="$(arg rate)" />
        <param name="input_mode" type="string" value="$(arg input_mode)" />
        <param name="arrow_topic" type="string" value="$(arg arrow_topic)" />
        <param name="arrow_class" type="string" value="$(arg arrow_class)" />
        <param name="min_confidence" type="double" value="$(arg min_confidence)" />
        <param name="arrow_forward" type="double" value="$(arg arrow_forward)" />
        <param name="arrow_right" type="double" value="$(arg arrow_right)" />
        <param name="arrow_down" type="double" value="$(arg arrow_down)" />
        <param name="search_step" type="double" value="$(arg search_step)" />
        <param name="max_search_points" type="int" value="$(arg max_search_points)" />
        <param name="scan_yaw_offsets_deg" type="string" value="$(arg scan_yaw_offsets_deg)" />
        <param name="scan_hold_seconds" type="double" value="$(arg scan_hold_seconds)" />
        <param name="max_search_seconds" type="double" value="$(arg max_search_seconds)" />
        <param name="search_arrive_dist" type="double" value="$(arg search_arrive_dist)" />
        <param name="search_arrive_yaw_deg" type="double" value="$(arg search_arrive_yaw_deg)" />
        <param name="stable_detection_count" type="int" value="$(arg stable_detection_count)" />
        <param name="stable_position_tolerance" type="double" value="$(arg stable_position_tolerance)" />
        <param name="detection_timeout" type="double" value="$(arg detection_timeout)" />
        <param name="arrow_yaw_mode" type="string" value="$(arg arrow_yaw_mode)" />
        <param name="fixed_arrow_yaw_deg" type="double" value="$(arg fixed_arrow_yaw_deg)" />
        <param name="arrive_dist" type="double" value="$(arg arrive_dist)" />
        <param name="arrive_yaw_deg" type="double" value="$(arg arrive_yaw_deg)" />
        <param name="hold_seconds" type="double" value="$(arg hold_seconds)" />
    </node>
</launch>
