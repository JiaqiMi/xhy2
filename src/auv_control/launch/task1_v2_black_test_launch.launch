<launch>
    <!--
        Task1 V2 黑色方形动作单独测试
        使用方式：
        1. 先启动真实基础节点：roslaunch auv_control begin.launch
        2. 再启动本文件：roslaunch auv_control task1_v2_black_test_launch.launch

        测试流程：
        当前位置作为起点 → 向前 0.5 m → 绿灯闪烁两次 → 原地旋转 360 度 → 结束
    -->

    <arg name="test_distance" default="0.5" />

    <!-- ActuatorControl 默认值：保持真实安全默认值 -->
    <param name="task_v2_heading_servo" type="int" value="128" />
    <param name="task_v2_clamp_servo" type="int" value="0" />
    <param name="task_v2_drive_cmd" type="int" value="0" />
    <param name="task_v2_drive_speed" type="int" value="0" />

    <node pkg="auv_control" type="task1_v2_black_test.py" name="task1_v2_black_test" output="screen">
        <param name="test_distance" type="double" value="$(arg test_distance)" />
        <param name="max_xy_step" type="double" value="0.15" />
        <param name="max_yaw_step_deg" type="double" value="3.0" />
        <param name="position_tolerance" type="double" value="0.15" />
        <param name="yaw_tolerance_deg" type="double" value="5.0" />
    </node>
</launch>
