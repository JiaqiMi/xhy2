<launch>
    <!--
        Task1 巡线单项测试。
        启动前需要先运行真实下位机、TF、motion_supervisor、相机和红线识别节点。
        本节点不会发布 /cmd/pose/ned，motion_supervisor 必须是其唯一发布者。
        每周期完整诊断使用 rospy.logdebug 并写入节点日志文件；
        屏幕只显示阶段、节流摘要、警告和错误（INFO 及以上）。
        节点不再接收人工初始航向；启动瞬间 base_link 的实际航向就是搜索航向。
        巡线使用 base_link 投影；LOS 新目标出现时立即下发当前位置到目标点的中点，
        不等待旧目标到达。没有新目标时保持最后目标，由控制器完成平移和转向，
        HOVER 连续确认后固定 XY 左右旋转搜索新的曲线延伸。
    -->

    <!-- 基础：主循环频率，单位 Hz。 -->
    <arg name="rate" default="5.0" />
    <!-- 红线识别点统一转换到的世界坐标系。 -->
    <arg name="map_frame" default="map" />

    <!-- motion_supervisor 接口：绝对目标、取消和状态反馈。 -->
    <arg name="motion_goal_topic" default="/cmd/motion/goal" />
    <arg name="motion_cancel_topic" default="/cmd/motion/cancel" />
    <arg name="motion_state_topic" default="/motion/state" />
    <arg name="motion_state_timeout" default="5" />

    <!-- 红线识别、任务完成、相机和轨迹 JSON。 -->
    <arg name="line_topic" default="/obj/line_message" />
    <arg name="finished_topic" default="/finished" />
    <arg name="camera_topic" default="/left/image_raw" />
    <!-- 双目坐标系仅用于 Web 航向箭头和日志；巡线控制固定使用 base_link。 -->
    <arg name="line_tracking_frame" default="camera" />
    <arg name="trajectory_topic" default="/task1/v3/trajectory" />
    <!-- 每次启动新建带时间戳的 YAML 分析数据文件。 -->
    <arg name="log_directory"
         default="$(env HOME)/.ros/auv_logs/task1" />

    <!-- 未识别红线：左右转并回到启动航向后，提交前方绝对目标的距离，单位 m。 -->
    <arg name="search_forward_distance" default="0.5" />
    <!-- 搜索旋转：相对启动/末端基准航向左右旋转角度（deg）。
         NED 中默认正航向向右，search_yaw_sign=1；实机方向相反时改为 -1。 -->
    <arg name="search_yaw_angle_deg" default="30.0" />
    <arg name="search_yaw_sign" default="1.0" />

    <!-- 节点启动后提交初始位姿并等待 HOVER/识别模块的时间，单位 s。 -->
    <arg name="startup_hold_seconds" default="10.0" />
    <!-- 相机消息超过该时间未更新则认为相机未就绪，单位 s。 -->
    <arg name="camera_message_timeout" default="2.0" />
    <!-- 每帧红线只等待一次原时间戳 TF；超过该时间仍不可用则丢弃整帧，单位 s。 -->
    <arg name="tf_timeout_seconds" default="1" />
    <!-- 红线消息允许的最大年龄；过期帧不参与锁线或拟合，单位 s。 -->
    <arg name="line_message_max_age_seconds" default="5" />

    <!-- 可接受的红线类别名，多个名称使用英文逗号分隔。 -->
    <arg name="line_classes" default="line" />
    <!-- 首次见线后的候选窗口，窗口内累计所有高置信 positions 点，单位 s。 -->
    <arg name="line_lock_window_seconds" default="0.3" />
    <!-- 红线置信度硬下限；低于该值的整帧识别直接丢弃，不参与锁线和曲线拟合。 -->
    <arg name="line_min_confidence" default="0.70" />
    <!-- 达到置信度下限后，positions 中坐标有限的识别点全部直接进入拟合；NaN/Inf 跳过；
         关联距离、方向、内点比例、延伸间隔和回折门槛均已停用。 -->

    <!-- 新点与已有点距离小于该值时做平滑融合，不重复增加点，单位 m。
         高密度识别默认设为 0，仅合并完全重合点，避免正常近邻点被压缩。 -->
    <arg name="line_point_merge_distance" default="0.0" />
    <!-- 合并重复点时新识别值的权重，范围 0~1；越小越平滑，越大越跟随新观测。 -->
    <arg name="line_point_update_alpha" default="0.20" />
    <!-- 当前活动拟合窗口的原始点安全上限；正常冻结由后续帧确认触发，超限只裁剪旧活动点。 -->
    <arg name="line_curve_max_points" default="200" />
    <!-- 活动点超限裁剪后保留在远端的点数，用于固定曲线与新曲线平滑衔接。 -->
    <arg name="line_curve_overlap_points" default="40" />
    <!-- 实时拟合曲线及 LOS 执行曲线快照的采样点数。 -->
    <arg name="line_curve_sample_count" default="100" />
    <!-- 平滑曲线的多项式拟合阶数。 -->
    <arg name="line_curve_degree" default="3" />
    <!-- 在线冻结：连续多少个高置信拟合帧后，把当前曲线立即固定。默认 2 帧。 -->
    <arg name="curve_freeze_required_frames" default="2" />
    <!-- 首段固定所需最短长度、后续每次固定所需最小增长，单位 m。 -->
    <arg name="curve_freeze_min_length" default="0.15" />
    <arg name="curve_freeze_min_advance" default="0.10" />
    <!-- 每次固定后保留在固定末端附近的原始衔接点范围，单位 m。 -->
    <arg name="curve_freeze_overlap_distance" default="0.25" />
    <!-- 最远点相对固定参考点至少增加该距离，才记为一次有效轨迹增长，单位 m。 -->
    <arg name="endpoint_growth_tolerance" default="0.08" />

    <!-- LOS 曲线前视距离，单位 m。 -->
    <arg name="los_lookahead_distance" default="0.6" />
    <!-- 实际位置目标位于 base_link 到 LOS 点连线上的比例；0.5 表示中点。 -->
    <arg name="los_midpoint_ratio" default="0.50" />
    <!-- LOS 点相对上次至少前移该距离才下发新中点，避免同一点反复重算，单位 m。 -->
    <arg name="los_target_update_min_distance" default="0.08" />
    <!-- 最后目标停止更新后，MotionState.HOVER 必须连续保持的时间，单位 s。 -->
    <arg name="motion_hover_confirm_seconds" default="3.0" />

    <!-- 进入终点定点后，曲线在该时间内不再增长才结束任务，单位 s。 -->
    <arg name="endpoint_confirm_seconds" default="5.0" />
    <!-- 允许结束任务前必须实际完成的最短巡线路径，单位 m；比赛红线长 5~8 m，默认留 0.5 m 余量。 -->
    <arg name="endpoint_min_completed_path_length" default="2" />
    <!-- 同一最远点必须被连续观测的帧数；达到后才形成真实终点证据。 -->
    <arg name="endpoint_stable_frames" default="8" />
    <!-- 多帧最远点视为同一位置的最大坐标偏差，单位 m。 -->
    <arg name="endpoint_stable_position_tolerance" default="0.12" />
    <!-- base_link 距当前最远点小于该值后才累计终点重复观测，避免把初始视野边缘当作终点，单位 m。 -->
    <arg name="endpoint_evidence_robot_distance" default="0.8" />

    <!-- 轨迹 JSON 和网页数据刷新周期，单位 s。 -->
    <arg name="trajectory_publish_period" default="0.5" />
    <!-- Web 实际运动轨迹相邻记录点最小间距（m）和最大保存点数。 -->
    <arg name="actual_path_min_spacing" default="0.03" />
    <arg name="actual_path_max_points" default="2000" />
    <!-- Web 历史有效识别点的显示合并距离，单位 m；只减少重叠绘制，不参与拟合。
         高密度点建议保持 0.01；设为 0 时保留每个有效点。 -->
    <arg name="web_valid_point_merge_distance" default="0.01" />
    <!-- Web 历史有效识别点的最大保存数量；到达上限后淘汰最早的显示点。 -->
    <arg name="web_valid_point_max_count" default="20000" />
    <!-- 是否启动巡线轨迹网页。 -->
    <arg name="trajectory_web_enabled" default="true" />
    <!-- 网页绑定的机器人本机网卡地址。 -->
    <arg name="trajectory_web_host" default="192.168.1.117" />
    <!-- 网页端口；默认访问 http://192.168.1.117:8083。 -->
    <arg name="trajectory_web_port" default="8083" />
<arg name="start_line_node" default="false" />

<include if="$(arg start_line_node)"
             file="$(find stereo_depth)/launch/test_line_detection_lineN.launch" />
    <node pkg="auv_control"
          type="test_task1_v3_line_follow.py"
          name="test_task1_v3_line_follow"
          output="screen">
        <!-- 文件记录 DEBUG 及以上，屏幕只显示 INFO 及以上。 -->
        <env name="ROS_PYTHON_LOG_CONFIG_FILE"
             value="$(find auv_control)/config/task1_v3_python_logging.conf" />
        <param name="rate" type="double" value="$(arg rate)" />
        <param name="map_frame" type="string" value="$(arg map_frame)" />

        <param name="motion_goal_topic" type="string" value="$(arg motion_goal_topic)" />
        <param name="motion_cancel_topic" type="string" value="$(arg motion_cancel_topic)" />
        <param name="motion_state_topic" type="string" value="$(arg motion_state_topic)" />
        <param name="motion_state_timeout" type="double" value="$(arg motion_state_timeout)" />
        <param name="line_topic" type="string" value="$(arg line_topic)" />
        <param name="finished_topic" type="string" value="$(arg finished_topic)" />
        <param name="camera_topic" type="string" value="$(arg camera_topic)" />
        <param name="line_tracking_frame" type="string" value="$(arg line_tracking_frame)" />
        <param name="trajectory_topic" type="string" value="$(arg trajectory_topic)" />
        <param name="log_directory" type="string" value="$(arg log_directory)" />

        <param name="search_forward_distance" type="double" value="$(arg search_forward_distance)" />
        <param name="search_yaw_angle_deg" type="double" value="$(arg search_yaw_angle_deg)" />
        <param name="search_yaw_sign" type="double" value="$(arg search_yaw_sign)" />

        <param name="startup_hold_seconds" type="double" value="$(arg startup_hold_seconds)" />
        <param name="camera_message_timeout" type="double" value="$(arg camera_message_timeout)" />
        <param name="tf_timeout_seconds" type="double" value="$(arg tf_timeout_seconds)" />
        <param name="line_message_max_age_seconds" type="double" value="$(arg line_message_max_age_seconds)" />

        <param name="line_classes" type="string" value="$(arg line_classes)" />
        <param name="line_lock_window_seconds" type="double" value="$(arg line_lock_window_seconds)" />
        <param name="line_min_confidence" type="double" value="$(arg line_min_confidence)" />

        <param name="line_point_merge_distance" type="double" value="$(arg line_point_merge_distance)" />
        <param name="line_point_update_alpha" type="double" value="$(arg line_point_update_alpha)" />
        <param name="line_curve_max_points" type="int" value="$(arg line_curve_max_points)" />
        <param name="line_curve_overlap_points" type="int" value="$(arg line_curve_overlap_points)" />
        <param name="line_curve_sample_count" type="int" value="$(arg line_curve_sample_count)" />
        <param name="line_curve_degree" type="int" value="$(arg line_curve_degree)" />
        <param name="curve_freeze_required_frames" type="int" value="$(arg curve_freeze_required_frames)" />
        <param name="curve_freeze_min_length" type="double" value="$(arg curve_freeze_min_length)" />
        <param name="curve_freeze_min_advance" type="double" value="$(arg curve_freeze_min_advance)" />
        <param name="curve_freeze_overlap_distance" type="double" value="$(arg curve_freeze_overlap_distance)" />
        <param name="endpoint_growth_tolerance" type="double" value="$(arg endpoint_growth_tolerance)" />

        <param name="los_lookahead_distance" type="double" value="$(arg los_lookahead_distance)" />
        <param name="los_midpoint_ratio" type="double" value="$(arg los_midpoint_ratio)" />
        <param name="los_target_update_min_distance" type="double" value="$(arg los_target_update_min_distance)" />
        <param name="motion_hover_confirm_seconds" type="double" value="$(arg motion_hover_confirm_seconds)" />
        <param name="endpoint_confirm_seconds" type="double" value="$(arg endpoint_confirm_seconds)" />
        <param name="endpoint_min_completed_path_length" type="double" value="$(arg endpoint_min_completed_path_length)" />
        <param name="endpoint_stable_frames" type="int" value="$(arg endpoint_stable_frames)" />
        <param name="endpoint_stable_position_tolerance" type="double" value="$(arg endpoint_stable_position_tolerance)" />
        <param name="endpoint_evidence_robot_distance" type="double" value="$(arg endpoint_evidence_robot_distance)" />

        <param name="trajectory_publish_period" type="double" value="$(arg trajectory_publish_period)" />
        <param name="actual_path_min_spacing" type="double" value="$(arg actual_path_min_spacing)" />
        <param name="actual_path_max_points" type="int" value="$(arg actual_path_max_points)" />
        <param name="web_valid_point_merge_distance" type="double" value="$(arg web_valid_point_merge_distance)" />
        <param name="web_valid_point_max_count" type="int" value="$(arg web_valid_point_max_count)" />
        <param name="trajectory_web_enabled" type="bool" value="$(arg trajectory_web_enabled)" />
        <param name="trajectory_web_host" type="string" value="$(arg trajectory_web_host)" />
        <param name="trajectory_web_port" type="int" value="$(arg trajectory_web_port)" />
    </node>
</launch>
